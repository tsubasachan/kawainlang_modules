🎀 ✅ cli_tem_flag(📕(🔡, 🔡) args, 🔡 nome) 🟢
    ❓ 🚫 (nome 🧲 args) 🟢
        🔙 👎
    ✨
    🔡 valor = args[nome]
    🔙 valor 🤝 "👍"
✨

🎀 🔡 cli_valor(📕(🔡, 🔡) args, 🔡 nome, 🔡 padrao) 🟢
    🔡 valor = args[nome]
    ❓ valor 📏 🤝 0 🟢
        🔙 padrao
    ✨
    🔙 valor
✨

🎀 🔢 cli_valor_int(📕(🔡, 🔡) args, 🔡 nome, 🔢 padrao) 🟢
    🔡 valor = args[nome]
    ❓ valor 📏 🤝 0 🟢
        🔙 padrao
    ✨
    🔙 valor ➡️ 🔢
✨

🎀 ✅ cli_pediu_help(📕(🔡, 🔡) args) 🟢
    🔡 valor = args["__help"]
    🔙 valor 🤝 "👍"
✨

🎀 🔡 cli_help() 🟢
    🌍 __cli_nome
    🌍 __cli_descricao
    🌍 __cli_flags
    🌍 __cli_args
    🔡 texto = "Uso: " + __cli_nome
    ❓ __cli_args 📏 > 0 🟢
        📦🔡 args = __cli_args 🪓 "\n"
        🔢 a = 0
        ➿ a < args 📏 🟢
            📦🔡 partes_arg = args[a] 🪓 "|"
            texto = texto + " <" + partes_arg[0] + ">"
            a = a + 1
        ✨
    ✨

    ❓ __cli_descricao 📏 > 0 🟢
        texto = texto + "\n\n" + __cli_descricao
    ✨

    ❓ __cli_flags 📏 > 0 🟢
        texto = texto + "\n\nOpcoes:"
        📦🔡 flags = __cli_flags 🪓 "\n"
        🔢 i = 0
        ➿ i < flags 📏 🟢
            📦🔡 partes = flags[i] 🪓 "|"
            🔡 linha = "  --" + partes[0]
            ❓ partes[1] 📏 > 0 🟢
                linha = linha + ", -" + partes[1]
            ✨
            ❓ partes[2] 🤝 "1" 🟢
                linha = linha + " <valor>"
            ✨
            linha = linha + "  " + partes[3]
            texto = texto + "\n" + linha
            i = i + 1
        ✨
        texto = texto + "\n  --help, -h  Mostra esta ajuda"
    ✨

    🔙 texto
✨
