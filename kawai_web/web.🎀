🎀 🔢 web_server(🔡 host, 🔢 porta) 🟢
    log_info("KawaiWeb iniciando em " + host + ":" + porta)
    🔙 http_server(host, porta)
✨

🎀 🔢 web_server_env() 🟢
    🔙 web_server(web_host(), web_port())
✨

🎀 🔢 web_accept(🔢 servidor) 🟢
    🔙 http_accept(servidor)
✨

🎀 📕(🔡, 🔡) web_request(🔢 cliente) 🟢
    🔡 bruto = http_recv(cliente)
    📕(🔡, 🔡) req = http_parse_request(bruto)
    📕(🔡, 🔡) ctx = {"method": req["method"], "path": req["path"]}
    log_evento("info", "request", ctx)
    🔙 req
✨

🎀 ✅ web_route(📕(🔡, 🔡) req, 🔡 method, 🔡 pattern) 🟢
    🔙 (req["method"] 🤝 method) 🔗 http_match_path(pattern, req["path"])
✨

🎀 🔡 web_param(📕(🔡, 🔡) req, 🔡 pattern, 🔡 nome) 🟢
    🔙 http_path_param(pattern, req["path"], nome)
✨

🎀 📕(🔡, 🔡) web_query(📕(🔡, 🔡) req) 🟢
    🔙 http_query(req)
✨

🎀 🔡 web_header(📕(🔡, 🔡) req, 🔡 nome) 🟢
    🔙 http_header(req, nome)
✨

🎀 🔢 web_log_request(📕(🔡, 🔡) req) 🟢
    📕(🔡, 🔡) ctx = {"method": req["method"], "path": req["path"]}
    log_evento("info", "request", ctx)
    🔙 0
✨

🎀 ✅ web_auth_header(📕(🔡, 🔡) req, 🔡 nome, 🔡 esperado) 🟢
    🔙 web_header(req, nome) 🤝 esperado
✨

🎀 🔡 web_unauthorized() 🟢
    🔙 http_response(401, "text/plain", "Nao autorizado")
✨

🎀 🔢 web_send_unauthorized(🔢 cliente) 🟢
    🔙 http_send_text(cliente, 401, "text/plain", "Nao autorizado")
✨

🎀 🔡 web_add_header(🔡 response, 🔡 nome, 🔡 valor) 🟢
    🔡 marcador = "\r\n\r\n"
    🔢 pos = -1
    🔢 i = 0

    ➿ i + 4 👈 response 📏 🟢
        ❓ (pos 🤝 -1) 🔗 ((response ✂️ i 👉 (i + 4)) 🤝 marcador) 🟢
            pos = i
        ✨
        i = i + 1
    ✨

    ❓ pos 👈 -1 🟢
        🔙 response
    ✨

    🔡 antes = response ✂️ 0 👉 pos
    🔡 depois = response ✂️ pos 👉
    🔙 antes + "\r\n" + nome + ": " + valor + depois
✨

🎀 🔡 web_cors(🔡 response, 🔡 origem) 🟢
    🔡 com_origem = web_add_header(response, "Access-Control-Allow-Origin", origem)
    🔡 com_metodos = web_add_header(com_origem, "Access-Control-Allow-Methods", "GET, POST, PUT, PATCH, DELETE, OPTIONS")
    🔙 web_add_header(com_metodos, "Access-Control-Allow-Headers", "Content-Type, Authorization")
✨

🎀 🔡 web_text(🔡 body) 🟢
    🔙 http_response(200, "text/plain", body)
✨

🎀 🔡 web_json(📕(🔡, 🔡) dados) 🟢
    🔙 http_response(200, "application/json", codificar(dados))
✨

🎀 🔡 web_escape_html(🔡 texto) 🟢
    🔡 resultado = texto
    resultado = resultado 🔄 "&" ➡ "&amp;"
    resultado = resultado 🔄 "<" ➡ "&lt;"
    resultado = resultado 🔄 ">" ➡ "&gt;"
    resultado = resultado 🔄 "\"" ➡ "&quot;"
    resultado = resultado 🔄 "'" ➡ "&#39;"
    🔙 resultado
✨

🎀 🔡 web_template(🔡 template, 📕(🔡, 🔡) contexto) 🟢
    🔡 html = template
    ➰ 🔡 chave 🧲 contexto 🟢
        🔡 marcador = "{" + chave + "}"
        🔡 valor = web_escape_html(contexto[chave])
        html = html 🔄 marcador ➡ valor
    ✨
    🔙 html
✨

🎀 🔡 web_html(🔡 body) 🟢
    🔙 http_response(200, "text/html; charset=utf-8", body)
✨

🎀 🔡 web_response(🔢 status, 🔡 content_type, 🔡 body) 🟢
    🔙 http_response(status, content_type, body)
✨

🎀 🔢 web_send(🔢 cliente, 🔡 response) 🟢
