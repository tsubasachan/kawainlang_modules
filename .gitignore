# Python cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# KawaiLang Compiler outputs
*.o
*.obj
*.ll
*.bc

# Compiled executables (any file without extension, or specifically test executables)
# We can ignore specific generated files or keep a generic block
# Since modules might contain test programs, let's ignore commonly built bin files.
# Usually, executables generated by kawailang compiler don't have extension on Linux.
# So we can ignore them by listing them or using common build exclusions.

# Editor and OS noise
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# Local logs
*.log
